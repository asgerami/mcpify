# Copy to .env and fill in. docker-compose reads these automatically.

# Encrypts stored credentials + OAuth tokens at rest (also enables OAuth).
# Generate one with:  openssl rand -hex 32
MCPIFY_SECRET_KEY=

# Required Bearer token for the management API + dashboard.
# Generate one with:  openssl rand -hex 24
MCPIFY_ADMIN_TOKEN=

# Public https origin behind your TLS proxy (used for OAuth redirect URIs).
# e.g. https://mcp.yourdomain.com
MCPIFY_PUBLIC_URL=http://localhost:4000
