{
  "info": {
    "_postman_id": "a1b2c3d4-0000-0000-0000-000000000000",
    "name": "JSONPlaceholder (Postman)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "baseUrl", "value": "https://jsonplaceholder.typicode.com" }],
  "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
  "item": [
    {
      "name": "Posts",
      "item": [
        {
          "name": "List posts",
          "request": {
            "method": "GET",
            "description": "List all posts, optionally filtered by author.",
            "url": {
              "raw": "{{baseUrl}}/posts?userId=1",
              "host": ["{{baseUrl}}"],
              "path": ["posts"],
              "query": [
                { "key": "userId", "value": "1", "description": "Filter by author id." }
              ]
            }
          }
        },
        {
          "name": "Get post by id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/:id",
              "host": ["{{baseUrl}}"],
              "path": ["posts", ":id"],
              "variable": [{ "key": "id", "description": "The post id to fetch." }]
            }
          }
        },
        {
          "name": "Create post",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"hello\",\n  \"body\": \"world\",\n  \"userId\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            }
          }
        }
      ]
    }
  ]
}
